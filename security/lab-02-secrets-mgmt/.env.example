# Copy to .env for local development — never commit .env
# .env is used ONLY to configure which secret to fetch from Secrets Manager,
# NOT to store the secret value itself.

# Name or ARN of the Secrets Manager secret (output of `terraform output secret_name`)
APP_SECRET_NAME=docker-cicd-labs/prod/app-credentials

# AWS region where the secret lives
AWS_REGION=eu-west-3

# For local runs: use a named AWS profile instead of injecting keys
# (uncomment if not using instance role or OIDC)
# AWS_PROFILE=my-dev-profile
