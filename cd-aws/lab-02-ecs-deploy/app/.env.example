# ── Local development only ───────────────────────────────────────────────────
# Copy to .env and fill in. Never commit .env to git.
# In production, all values come from ECS task definition or GitHub secrets.

# Application
APP_VERSION=dev
ENVIRONMENT=local
PORT=5000

# AWS — used by Terraform and the AWS CLI locally
AWS_DEFAULT_REGION=eu-west-3

# Set after `terraform apply` (copy from terraform output)
ECR_URI=123456789012.dkr.ecr.eu-west-3.amazonaws.com/ecs-lab02-app
ECS_CLUSTER=ecs-lab02-cluster
ECS_SERVICE=ecs-lab02-service
AWS_ROLE_ARN=arn:aws:iam::123456789012:role/ecs-lab02-github-actions-role
