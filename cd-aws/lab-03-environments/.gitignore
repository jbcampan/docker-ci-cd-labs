# task-definition.*.json are generated by `terraform apply` in staging/ and
# production/ modules. Do NOT commit them manually — commit only after Terraform
# has written them with the real ARNs. If you want to track them:
# remove the lines below and run `git add task-definition.*.json`.
# task-definition.staging.json
# task-definition.production.json

# Environment secrets
.env

# Terraform working files — all three modules
terraform/bootstrap/.terraform/
terraform/bootstrap/.terraform.lock.hcl
terraform/bootstrap/terraform.tfstate
terraform/bootstrap/terraform.tfstate.backup

terraform/shared/.terraform/
terraform/shared/.terraform.lock.hcl
terraform/shared/*.tfvars
!terraform/shared/shared.tfvars      # keep the example as reference

terraform/staging/.terraform/
terraform/staging/.terraform.lock.hcl
terraform/staging/*.tfvars
!terraform/staging/staging.tfvars      # keep the example as reference

terraform/production/.terraform/
terraform/production/.terraform.lock.hcl
terraform/production/*.tfvars
!terraform/production/production.tfvars  # keep the example as reference
