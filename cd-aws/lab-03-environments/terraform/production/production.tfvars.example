# ---------------------------------------------------------------------------
# Production-specific variable values.
# Apply with: terraform apply -var-file=production.tfvars
#
# Sizing is intentionally IDENTICAL to staging.tfvars (same CPU, memory,
# desired_count, health check). The point of this lab is the deployment
# pipeline (manual approval gate), not infrastructure scaling. Only
# `project`, `environment`, and the OIDC provider creation flag differ.
# ---------------------------------------------------------------------------

aws_region  = "eu-west-3"
project     = "ecs-lab03-production"
environment = "production"
app_version = "latest"

vpc_cidr            = "10.0.0.0/16"
public_subnet_cidrs = ["10.0.1.0/24", "10.0.2.0/24"]

# Identical sizing to staging on purpose for this lab — see README.
task_cpu       = 256
task_memory    = 512
desired_count  = 1
container_port = 5000

health_check_path = "/health"

# ⚠️ Replace with your own values before applying — MUST match staging.tfvars
# (same repo, same state bucket).
github_repo    = "your-github-username/docker-ci-cd-labs"
tfstate_bucket = "REPLACE_WITH_BOOTSTRAP_BUCKET_NAME"


