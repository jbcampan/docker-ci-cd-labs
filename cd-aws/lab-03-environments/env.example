# ── Local development only ───────────────────────────────────────────────────
# Copy to .env and fill in. Never commit .env to git.
# In production, all values come from the ECS task definition or GitHub
# Environment secrets — this file is only used for local `docker run` tests.

# Application
APP_VERSION=dev
ENVIRONMENT=local
PORT=5000

# AWS — used by Terraform and the AWS CLI locally
AWS_DEFAULT_REGION=eu-west-3

# ── Set after `terraform apply` for the shared module ────────────────────────
ECR_URI=123456789012.dkr.ecr.eu-west-3.amazonaws.com/ecs-lab03-app

# Role with ECR-push-only rights (repo-level secret AWS_ROLE_ARN_PUSH)
AWS_ROLE_ARN_PUSH=arn:aws:iam::123456789012:role/ecs-lab03-github-actions-push-role

# ── Set after `terraform apply` for the STAGING module ───────────────────────
AWS_ROLE_ARN_STAGING=arn:aws:iam::123456789012:role/ecs-lab03-staging-github-actions-role
ECS_CLUSTER_STAGING=ecs-lab03-staging-cluster
ECS_SERVICE_STAGING=ecs-lab03-staging-service

# ── Set after `terraform apply` for the PRODUCTION module ────────────────────
AWS_ROLE_ARN_PRODUCTION=arn:aws:iam::123456789012:role/ecs-lab03-production-github-actions-role
ECS_CLUSTER_PRODUCTION=ecs-lab03-production-cluster
ECS_SERVICE_PRODUCTION=ecs-lab03-production-service

# S3 backend (used in backend.tf of each module)
TFSTATE_BUCKET=tfstate-yourname-docker-cicd-labs
