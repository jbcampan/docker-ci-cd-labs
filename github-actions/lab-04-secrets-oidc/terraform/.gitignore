# Local Terraform state — never commit to git
.terraform/
.terraform.lock.hcl
terraform.tfstate
terraform.tfstate.backup

# Real variable values — use terraform.tfvars.example as template
terraform.tfvars

# Crash logs
crash.log
crash.*.log

# Override files (local experiments)
override.tf
override.tf.json
*_override.tf
*_override.tf.json
