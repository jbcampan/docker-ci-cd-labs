# ── LocalStack / AWS credentials ─────────────────────────────────────────────
# LocalStack accepts any non-empty value for access key and secret.
# "test" is the conventional placeholder used by the LocalStack community.
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# ── Resource names ────────────────────────────────────────────────────────────
S3_BUCKET=lab04-bucket
SQS_QUEUE_NAME=lab04-queue

# ── Worker tuning ─────────────────────────────────────────────────────────────
# POLL_WAIT_TIME: SQS long-poll duration in seconds (1–20).
# Higher = fewer empty receives = lower cost in production.
POLL_WAIT_TIME=5

# VISIBILITY_TIMEOUT: seconds a message stays hidden while being processed.
# Must be > your worst-case processing time to avoid duplicate delivery.
VISIBILITY_TIMEOUT=30
