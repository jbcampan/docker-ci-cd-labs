# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=dev                   # dev | prod
APP_VERSION=1.0.0
APP_PORT=8080                 # host port mapped to container 5000

# ── Debug & feature flags ─────────────────────────────────────────────────────
DEBUG_MODE=true               # true | false
FEATURE_DARK_MODE=true        # true | false
FEATURE_ANALYTICS=false       # true | false

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=appdb
DB_USER=appuser
DB_PASSWORD=                  # required — never commit a real value here
